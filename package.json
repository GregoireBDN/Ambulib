{
  "name": "havrid",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run start:dev --filter=api",
    "dev:mobile": "turbo run start --filter=mobile",
    "dev:client": "turbo run dev --filter=client",
    "dev:fleet": "turbo run dev --filter=fleet",
    "dev:admin": "turbo run dev --filter=admin",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check": "manypkg check",
    "fix": "manypkg fix",
    "full-stack": "turbo run dev",
    "studio": "cd apps/api && npx prisma studio",
    "swagger": "cd apps/api && npm run start:dev",
    "storybook": "turbo run storybook",
    "storybook:ui": "turbo run storybook --filter=@repo/ui"
  },
  "devDependencies": {
    "@manypkg/cli": "^0.24.0",
    "prettier": "^3.4.2",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=18.0.0"
  }
}
