{
  "name": "ambulib",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "dev:api": "turbo run start:dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run start --filter=mobile",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check": "manypkg check",
    "fix": "manypkg fix"
  },
  "devDependencies": {
    "@manypkg/cli": "^0.24.0",
    "prettier": "^3.4.2",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=18.0.0"
  }
}
