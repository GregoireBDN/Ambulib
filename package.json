{
  "name": "ambulib",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run start:dev --filter=api...",
    "dev:web": "turbo run dev --filter=web...",
    "dev:mobile": "turbo run start --filter=mobile...",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check": "manypkg check",
    "fix": "manypkg fix",
    "check-types": "turbo run check-types",
    "nx:serve:web": "nx serve web",
    "nx:serve:api": "nx serve api",
    "nx:serve:all": "nx run-many --target=serve --projects=web,api --parallel"
  },
  "devDependencies": {
    "@manypkg/cli": "^0.24.0",
    "nx": "21.0.3",
    "prettier": "^3.4.2",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=18.0.0"
  }
}
