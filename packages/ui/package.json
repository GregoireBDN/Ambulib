{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./styles/globals.css": "./src/styles/globals.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles.css": "./dist/styles.css",
    "./tailwind.config.preset.js": "./tailwind.config.preset.js",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./components/accessible/*": "./src/components/accessible/*.tsx",
    "./components/auth/*": "./src/components/auth/*.tsx",
    "./lib/utils": "./src/lib/utils.ts"
  },
  "scripts": {
    "dev": "concurrently \"tsc --watch\" \"pnpm dev:styles\" \"pnpm storybook\"",
    "dev:styles": "npx tailwindcss --config ./tailwind.config.ts --input ./src/styles.css --output ./dist/styles.css --watch",
    "build": "concurrently \"tsc\" \"pnpm build:styles\"",
    "build:styles": "npx tailwindcss --config ./tailwind.config.ts --input ./src/styles.css --output ./dist/styles.css --minify",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve": "npx serve storybook-static -p 6006",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-backgrounds": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-viewport": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.24.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "storybook": "^8.6.14",
    "ts-jest": "^29.4.1",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/postcss": "4.1.10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.460.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.60.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "4.1.10",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
