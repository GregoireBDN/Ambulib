{
  "name": "@repo/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Package d'authentification partagé pour HavRid",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./mobile": {
      "types": "./dist/mobile/index.d.ts",
      "import": "./dist/mobile/index.js",
      "require": "./dist/mobile/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.12",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next": "^15.0.0",
    "react": "^19.1.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "keywords": [
    "authentication",
    "jwt",
    "oauth",
    "havrid",
    "monorepo"
  ]
}