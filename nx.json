{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "sharedGlobals": ["{workspaceRoot}/**/.env.*local"],
    "default": ["{projectRoot}/**/*", "sharedGlobals"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/.next/**",
        "!{projectRoot}/.next/cache/**",
        "{projectRoot}/dist/**",
        "{projectRoot}/build/**"
      ],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "start": {
      "cache": false
    },
    "start:dev": {
      "cache": false
    },
    "test": {
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "cache": true
    }
  }
}
