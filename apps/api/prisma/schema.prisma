generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int     @id @default(autoincrement())
  email              String  @unique
  name               String
  password           String
  hashedRefreshToken String?
  role               Role    @default(USER)
}

model Category {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  title String
  img   String?
}

enum Role {
  ADMIN
  EDITOR
  USER
}
