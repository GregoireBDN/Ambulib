generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                                   String            @unique
  password                                String
  id                                      Int               @id @default(autoincrement())
  hashedRefreshToken                      String?
  role                                    Role              @default(CLIENT)
  age                                     Int?
  firstName                               String
  lastName                                String
  phoneNumber                             String?
  address                                 String?
  authProvider                            AuthProvider      @default(CREDENTIALS)
  city                                    String?
  isProfileComplete                       Boolean           @default(false)
  postalCode                              String?
  createdAt                               DateTime          @default(now())
  updatedAt                               DateTime
  Ambulance                               Ambulance[]
  Assignment_Assignment_createdByIdToUser Assignment[]      @relation("Assignment_createdByIdToUser")
  Assignment_Assignment_driverIdToUser    Assignment[]      @relation("Assignment_driverIdToUser")
  Booking                                 Booking[]
  dependent                               Dependent[]
  emergencyContact                        EmergencyContact?
  MedicalInfo                             MedicalInfo[]
}

model EmergencyContact {
  id           Int     @id @default(autoincrement())
  firstName    String
  lastName     String
  phoneNumber  String
  email        String?
  relationship String
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
}

model Dependent {
  id          Int           @id @default(autoincrement())
  firstName   String
  lastName    String
  age         Int?
  userId      Int?
  address     String?
  city        String?
  phoneNumber String?
  postalCode  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Booking     Booking[]
  user        User?         @relation(fields: [userId], references: [id])
  MedicalInfo MedicalInfo[]
}

model Ambulance {
  id              Int             @id @default(autoincrement())
  licensePlate    String          @unique
  vehicleModel    String
  vehicleYear     Int
  capacity        Int             @default(1)
  status          AmbulanceStatus @default(AVAILABLE)
  driverId        Int?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  mileage         Int?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  User            User?           @relation(fields: [driverId], references: [id])
  Assignment      Assignment[]
}

model Assignment {
  id                                Int              @id @default(autoincrement())
  bookingId                         Int
  ambulanceId                       Int
  driverId                          Int
  createdById                       Int
  status                            AssignmentStatus @default(ASSIGNED)
  assignedAt                        DateTime         @default(now())
  acceptedAt                        DateTime?
  startedAt                         DateTime?
  completedAt                       DateTime?
  notes                             String?
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime
  Ambulance                         Ambulance        @relation(fields: [ambulanceId], references: [id])
  Booking                           Booking          @relation(fields: [bookingId], references: [id])
  User_Assignment_createdByIdToUser User             @relation("Assignment_createdByIdToUser", fields: [createdById], references: [id])
  User_Assignment_driverIdToUser    User             @relation("Assignment_driverIdToUser", fields: [driverId], references: [id])
}

model Booking {
  id                    Int                   @id @default(autoincrement())
  clientId              Int
  dependentId           Int?
  pickupAddress         String
  destinationAddress    String
  pickupCity            String
  destinationCity       String
  pickupPostalCode      String?
  destinationPostalCode String?
  scheduledDateTime     DateTime?
  bookingType           BookingType           @default(SCHEDULED)
  status                BookingStatus         @default(PENDING)
  specialRequirements   SpecialRequirements[]
  notes                 String?
  estimatedDuration     Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime
  Assignment            Assignment[]
  User                  User                  @relation(fields: [clientId], references: [id])
  Dependent             Dependent?            @relation(fields: [dependentId], references: [id])
  TransportTicket       TransportTicket[]
}

model MedicalInfo {
  id                    Int        @id @default(autoincrement())
  userId                Int
  dependentId           Int?
  allergies             String?
  medications           String?
  medicalConditions     String?
  emergencyInstructions String?
  bloodType             String?
  doctorName            String?
  doctorPhone           String?
  insuranceNumber       String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime
  Dependent             Dependent? @relation(fields: [dependentId], references: [id])
  User                  User       @relation(fields: [userId], references: [id])
}

model TransportTicket {
  id           Int       @id @default(autoincrement())
  bookingId    Int
  ticketNumber String    @unique
  issueDate    DateTime  @default(now())
  validUntil   DateTime?
  ticketType   String
  value        Float?
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Booking      Booking   @relation(fields: [bookingId], references: [id])
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FLEET_MANAGER
  AMBULANCE_DRIVER
  CLIENT
}

enum SpecialRequirements {
  NEEDS_OXYGEN
  NEEDS_LYING_TRANSPORT
  ALLERGIES
  MEDICATIONS
}

enum AmbulanceStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingType {
  SCHEDULED
  EMERGENCY
}
