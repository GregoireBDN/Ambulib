generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               Int           @id @default(autoincrement())
  name             String
  email            String        @unique
  phoneNumber      String?
  address          String?
  city             String?
  postalCode       String?
  licenseNumber    String?       @unique
  status           CompanyStatus @default(PENDING)
  registrationDate DateTime      @default(now())
  approvedAt       DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  users            User[]
  ambulances       Ambulance[]
}

model User {
  email              String            @unique
  password           String
  id                 Int               @id @default(autoincrement())
  hashedRefreshToken String?
  role               Role              @default(CLIENT)
  companyId          Int?
  age                Int?
  firstName          String
  lastName           String
  phoneNumber        String?
  address            String?
  authProvider       AuthProvider      @default(CREDENTIALS)
  city               String?
  isProfileComplete  Boolean           @default(false)
  postalCode         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  company            Company?          @relation(fields: [companyId], references: [id])
  dependent          Dependent[]
  emergencyContact   EmergencyContact?
  bookings           Booking[]
  medicalInfo        MedicalInfo[]
  assignedRoutes     Assignment[]      @relation("DriverAssignments")
  createdAssignments Assignment[]      @relation("CreatedByUser")
  ambulances         Ambulance[]       @relation("AmbulanceDriver")
}

model EmergencyContact {
  id           Int     @id @default(autoincrement())
  firstName    String
  lastName     String
  phoneNumber  String
  email        String?
  relationship String
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
}

model Dependent {
  id          Int           @id @default(autoincrement())
  firstName   String
  lastName    String
  age         Int?
  userId      Int?
  address     String?
  city        String?
  phoneNumber String?
  postalCode  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?   @relation(fields: [userId], references: [id])
  bookings    Booking[]
  medicalInfo MedicalInfo[]
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FLEET_MANAGER
  AMBULANCE_DRIVER
  CLIENT
}

enum CompanyStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum SpecialRequirements {
  NEEDS_OXYGEN
  NEEDS_LYING_TRANSPORT
  ALLERGIES
  MEDICATIONS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingType {
  SCHEDULED
  EMERGENCY
}

enum AmbulanceStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Booking {
  id                Int             @id @default(autoincrement())
  clientId          Int
  dependentId       Int?
  pickupAddress     String
  destinationAddress String
  pickupCity        String
  destinationCity   String
  pickupPostalCode  String?
  destinationPostalCode String?
  scheduledDateTime DateTime?
  bookingType       BookingType     @default(SCHEDULED)
  status            BookingStatus   @default(PENDING)
  specialRequirements SpecialRequirements[]
  notes             String?
  estimatedDuration Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  client            User            @relation(fields: [clientId], references: [id])
  dependent         Dependent?      @relation(fields: [dependentId], references: [id])
  transportTickets  TransportTicket[]
  assignments       Assignment[]
}

model MedicalInfo {
  id                Int      @id @default(autoincrement())
  userId            Int
  dependentId       Int?
  allergies         String?
  medications       String?
  medicalConditions String?
  emergencyInstructions String?
  bloodType         String?
  doctorName        String?
  doctorPhone       String?
  insuranceNumber   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  dependent         Dependent? @relation(fields: [dependentId], references: [id])
}

model TransportTicket {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  ticketNumber  String   @unique
  issueDate     DateTime @default(now())
  validUntil    DateTime?
  ticketType    String
  value         Float?
  isUsed        Boolean  @default(false)
  usedAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  booking       Booking  @relation(fields: [bookingId], references: [id])
}

model Ambulance {
  id              Int             @id @default(autoincrement())
  companyId       Int
  licensePlate    String          @unique
  vehicleModel    String
  vehicleYear     Int
  capacity        Int             @default(1)
  status          AmbulanceStatus @default(AVAILABLE)
  driverId        Int?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  mileage         Int?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id])
  driver          User?           @relation("AmbulanceDriver", fields: [driverId], references: [id])
  assignments     Assignment[]
}

model Assignment {
  id                Int              @id @default(autoincrement())
  bookingId         Int
  ambulanceId       Int
  driverId          Int
  createdById       Int
  status            AssignmentStatus @default(ASSIGNED)
  assignedAt        DateTime         @default(now())
  acceptedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  booking           Booking          @relation(fields: [bookingId], references: [id])
  ambulance         Ambulance        @relation(fields: [ambulanceId], references: [id])
  driver            User             @relation("DriverAssignments", fields: [driverId], references: [id])
  createdBy         User             @relation("CreatedByUser", fields: [createdById], references: [id])
}
