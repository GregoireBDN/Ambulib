generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  firstName           String
  lastName            String
  password            String
  hashedRefreshToken  String?
  phoneNumber         String?
  age                 Int?
  notes               String?
  medicalCondition    String?
  specialRequirements SpecialRequirements[]
  emergencyContact    EmergencyContact?
  dependent           Dependent[]
  role                Role                  @default(USER)
}

model Category {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  title String
  img   String?
}

enum Role {
  SUPER_ADMIN // Administrateur système avec tous les droits
  ADMIN // Administrateur du service ambulancier
  DRIVER // Conducteur d'ambulance
  USER // Utilisateur basique
}

model EmergencyContact {
  id           Int     @id @default(autoincrement())
  firstName    String
  lastName     String
  phoneNumber  String
  email        String?
  relationship String
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
}

model Dependent {
  id                  Int                   @id @default(autoincrement())
  firstName           String
  lastName            String
  age                 Int?
  notes               String?
  medicalCondition    String?
  specialRequirements SpecialRequirements[]
  userId              Int?
  user                User?                 @relation(fields: [userId], references: [id])
}

enum SpecialRequirements {
  NEEDS_OXYGEN
  NEEDS_LYING_TRANSPORT
  ALLERGIES
  MEDICATIONS
}
