generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email              String            @unique
  password           String
  id                 Int               @id @default(autoincrement())
  hashedRefreshToken String?
  role               Role              @default(CLIENT)
  age                Int?
  firstName          String
  lastName           String
  phoneNumber        String?
  address            String?
  authProvider       AuthProvider      @default(CREDENTIALS)
  city               String?
  country            String?           @default("France")
  isProfileComplete  Boolean           @default(false)
  postalCode         String?
  birthDate          DateTime?
  companyId          Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  ambulance          Ambulance?        @relation("AmbulanceDriver")
  driverAssignments  Assignment[]      @relation("DriverAssignments")
  clientBookings     Booking[]         @relation("ClientBookings")
  dependent          Dependent[]
  emergencyContact   EmergencyContact?
  medicalInfo        MedicalInfo?
  company            Company?          @relation(fields: [companyId], references: [id])
}

model EmergencyContact {
  id           Int     @id @default(autoincrement())
  firstName    String
  lastName     String
  phoneNumber  String
  email        String?
  relationship String
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
}

model Dependent {
  id          Int     @id @default(autoincrement())
  firstName   String
  lastName    String
  age         Int?
  userId      Int?
  address     String?
  city        String?
  country     String? @default("France")
  phoneNumber String?
  postalCode  String?
  user        User?   @relation(fields: [userId], references: [id])
}

model Category {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  title String
  img   String?
}

model MedicalInfo {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  allergies         String?
  medications       String?
  medicalConditions String?
  doctorName        String?
  doctorPhone       String?
  insuranceNumber   String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id            Int           @id @default(autoincrement())
  name          String
  licenseNumber String        @unique
  address       String
  phoneNumber   String
  email         String
  status        CompanyStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ambulances    Ambulance[]
  users         User[]
}

model Ambulance {
  id           Int             @id @default(autoincrement())
  licensePlate String          @unique
  model        String
  year         Int
  capacity     Int
  status       AmbulanceStatus @default(AVAILABLE)
  companyId    Int
  driverId     Int?            @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  company      Company         @relation(fields: [companyId], references: [id])
  driver       User?           @relation("AmbulanceDriver", fields: [driverId], references: [id])
  assignments  Assignment[]
}

model Booking {
  id                  Int                   @id @default(autoincrement())
  clientId            Int
  pickupAddress       String
  destinationAddress  String
  pickupDateTime      DateTime
  appointmentDateTime DateTime?
  returnTrip          Boolean               @default(false)
  returnDateTime      DateTime?
  status              BookingStatus         @default(PENDING)
  bookingType         BookingType
  specialRequirements SpecialRequirements[]
  notes               String?
  totalCost           Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  assignments         Assignment[]
  client              User                  @relation("ClientBookings", fields: [clientId], references: [id])
  transportTickets    TransportTicket[]
}

model Assignment {
  id          Int              @id @default(autoincrement())
  bookingId   Int
  ambulanceId Int
  driverId    Int
  status      AssignmentStatus @default(ASSIGNED)
  assignedAt  DateTime         @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  ambulance   Ambulance        @relation(fields: [ambulanceId], references: [id])
  booking     Booking          @relation(fields: [bookingId], references: [id])
  driver      User             @relation("DriverAssignments", fields: [driverId], references: [id])
}

model TransportTicket {
  id           Int       @id @default(autoincrement())
  bookingId    Int
  ticketNumber String    @unique
  issueDate    DateTime  @default(now())
  validUntil   DateTime
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  booking      Booking   @relation(fields: [bookingId], references: [id])
}

model EmailVerification {
  id         String   @id @default(cuid())
  email      String
  code       String
  expiresAt  DateTime
  attempts   Int      @default(0)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FLEET_MANAGER
  AMBULANCE_DRIVER
  CLIENT
}

enum CompanyStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum AmbulanceStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingType {
  MEDICAL_APPOINTMENT
  HOSPITAL_TRANSFER
  EMERGENCY
  ROUTINE_TRANSPORT
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SpecialRequirements {
  NEEDS_OXYGEN
  NEEDS_LYING_TRANSPORT
  ALLERGIES
  MEDICATIONS
}
