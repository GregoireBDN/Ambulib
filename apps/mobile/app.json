{
  "expo": {
    "name": "@havrid/mobile",
    "slug": "havrid-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "updates": {
      "enabled": false
    },
    "doctor": {
      "reactNativeDirectoryCheck": false,
      "expoGoCompatibilityCheck": false
    }
  }
}
